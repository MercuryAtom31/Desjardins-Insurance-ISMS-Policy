@startuml nist-csf-functions

skinparam backgroundColor #E8F0F2
skinparam ArrowColor #053742
skinparam RectangleBorderColor #39A2DB
skinparam RectangleBorderThickness 2
skinparam DefaultTextAlignment center

skinparam rectangle {
  FontName Arial
}

skinparam rectangle<<govern>> {
  BackgroundColor #053742
  FontColor #FFFFFF
}

skinparam rectangle<<identify>> {
  BackgroundColor #39A2DB
  FontColor #FFFFFF
}

skinparam rectangle<<protect>> {
  BackgroundColor #A2DBFA
  FontColor #053742
}

skinparam rectangle<<detect>> {
  BackgroundColor #39A2DB
  FontColor #FFFFFF
}

skinparam rectangle<<respond>> {
  BackgroundColor #053742
  FontColor #FFFFFF
}

skinparam rectangle<<recover>> {
  BackgroundColor #A2DBFA
  FontColor #053742
}

skinparam rectangle<<detail>> {
  BackgroundColor #E8F0F2
  FontColor #053742
}

title Desjardins Insurance - NIST CSF 2.0 Functions

legend top
  NIST CSF functions shown: Govern, Identify, Protect, Detect, Respond, Recover
endlegend

rectangle "GOVERN\n(GV)" as GV <<govern>>
rectangle "IDENTIFY\n(ID)" as ID <<identify>>
rectangle "PROTECT\n(PR)" as PR <<protect>>
rectangle "DETECT\n(DE)" as DE <<detect>>
rectangle "RESPOND\n(RS)" as RS <<respond>>
rectangle "RECOVER\n(RC)" as RC <<recover>>

rectangle "Project Focus:\n- Define ISMS governance\n- Set risk appetite\n- Assign CISO/Board oversight\n- Approve policy lifecycle" as GV_D <<detail>>
rectangle "Project Focus:\n- Inventory information assets\n- Classify PII/health/financial data\n- Assess threats and vulnerabilities\n- Prioritize risk treatment" as ID_D <<detail>>
rectangle "Project Focus:\n- Enforce least privilege + MFA\n- Encrypt data at rest/in transit\n- Apply secure SDLC + patching\n- Manage third-party controls" as PR_D <<detail>>
rectangle "Project Focus:\n- Centralize logs and monitoring\n- Define detection SLAs/KPIs\n- Perform internal security reviews\n- Identify anomalies and incidents" as DE_D <<detail>>
rectangle "Project Focus:\n- Run incident response process\n- Escalate and contain incidents\n- Meet breach notification duties\n- Track lessons learned" as RS_D <<detail>>
rectangle "Project Focus:\n- Execute backup and recovery plans\n- Restore critical insurance services\n- Validate post-incident stability\n- Feed improvements to governance" as RC_D <<detail>>

GV --> ID : Direction and\nrisk governance
ID --> PR : Prioritized\nsafeguards
PR --> DE : Monitoring and\nanomaly detection
DE --> RS : Incident\nresponse actions
RS --> RC : Restoration and\nresilience
RC --> GV : Governance\nfeedback loop

GV ..> PR : Policy and\ncontrol requirements
GV ..> DE : Oversight and\nassurance
ID ..> DE : Asset and risk\ncontext
RS ..> GV : Lessons learned

GV ..> GV_D
ID ..> ID_D
PR ..> PR_D
DE ..> DE_D
RS ..> RS_D
RC ..> RC_D

@enduml
