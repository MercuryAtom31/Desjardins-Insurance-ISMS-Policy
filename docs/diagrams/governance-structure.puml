@startuml governance-structure

skinparam backgroundColor #F6E7BC
skinparam ArrowColor #0B2D72
skinparam rectangle {
  BackgroundColor<<board>> #0B2D72
  BackgroundColor<<executive>> #0992C2
  BackgroundColor<<ciso>> #0B2D72
  BackgroundColor<<management>> #0992C2
  BackgroundColor<<operations>> #0AC4E0
  BackgroundColor<<support>> #0992C2
  BackgroundColor<<staff>> #F6E7BC
  FontColor<<board>> #ffffff
  FontColor<<executive>> #ffffff
  FontColor<<ciso>> #ffffff
  FontColor<<management>> #ffffff
  FontColor<<operations>> #0B2D72
  FontColor<<support>> #ffffff
  FontColor<<staff>> #0B2D72
  BorderColor #0992C2
  BorderThickness 2
}

title Desjardins Insurance - Information Security Governance Structure

' Board and Executive Level
rectangle "Board of Directors" as BOD <<board>>
rectangle "Chief Executive Officer\n(CEO)" as CEO <<executive>>

' CISO and Direct Reports
rectangle "CISO" as CISO <<ciso>>
rectangle "Security Policy\nManager" as SPM <<management>>
rectangle "Privacy Officer" as PO <<management>>

' IT and Security Operations
rectangle "Identity & Access\nManagement" as IAM <<operations>>
rectangle "Encryption &\nData Protection" as EDP <<operations>>
rectangle "Patching &\nVulnerability Mgmt" as PVM <<operations>>
rectangle "Logging &\nMonitoring" as LM <<operations>>

' Supporting Functions
rectangle "Business Unit\nManagers" as BUM <<support>>
rectangle "Human\nResources" as HR <<support>>
rectangle "Legal &\nCompliance" as LC <<support>>
rectangle "Third-Party &\nVendor Management" as TPM <<support>>

' Staff Level
rectangle "Employees" as EMP <<staff>>

' Reporting Lines
BOD --> CEO : Governance\nOversight
CEO --> CISO : Reports to &\nEnsures Champion
CISO --> SPM : Operates Day-to-Day\nPolicy Activities
CISO --> PO : Privacy\nCompliance
CISO --> IAM : Implements Technical\nControls
CISO --> EDP : Manages Data\nSecurity
CISO --> PVM : Manages Patching\n& Vulnerabilities
CISO --> LM : Monitoring &\nDetection
CISO --> BUM : Ensures Controls\nApplied
CISO --> HR : Enforces Training\n& Onboarding
CISO --> LC : Regulatory &\nContractual Advice
CISO --> TPM : Vendor Risk\nAssessment

BUM --> EMP : Direct\nManagement
HR --> EMP : HR\nServices

@enduml
